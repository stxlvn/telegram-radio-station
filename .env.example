# Copy this file to /etc/musicbestman/env (referenced by the systemd units
# in systemd/) and fill in real values. Never commit the filled-in file.

# --- Required ---

# api_id / api_hash from https://my.telegram.org -- used by every script
# that talks to Telegram (queue filler, now-playing publisher, RTMP relay,
# subscriber counter, one-off indexing scripts).
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# The channel (username, no @) whose audio archive is streamed.
TELEGRAM_CHANNEL=

# Icecast source password, matches whatever is set in icecast.xml's
# <source-password>.
ICECAST_PASSWORD=

# Full rtmps:// URL (including the embedded stream key) from Telegram's
# "Start streaming" dialog for the target chat/channel video call.
TGSTREAM_RTMP_URL=

# --- Optional ---

# Discogs personal access token (Settings -> Developers -> Generate new
# token on discogs.com). Without it, metadata enrichment still runs off
# file tags / Telegram message fields / the channel's own description
# posts -- it just skips the Discogs lookup step silently.
DISCOGS_TOKEN=

# YouTube Data API v3 key (Google Cloud Console -> APIs & Services ->
# Credentials), used server-side to look up a matching music video link for
# the current track. Free quota is 10,000 units/day and a search costs 100,
# which a station changing tracks every few minutes will burn through in a
# few hours -- once it's exhausted, lookups silently fall back to yt-dlp
# (see YTDLP_BIN) instead of failing outright. Without a key at all, this
# just skips straight to the yt-dlp fallback.
YOUTUBE_API_KEY=

# Path to the yt-dlp binary, used only as a fallback for the above once the
# API quota runs out -- defaults to whatever "yt-dlp" resolves to on PATH.
# YTDLP_BIN=/opt/radio/venv/bin/yt-dlp

# Override any of these if you're not using the default /opt layout.
# TELEGRAM_SESSION_PATH=/opt/radio/session
# TGSTREAM_SESSION_PATH=/opt/tgstream/session
# TELEGRAM_SESSION_LOCK_PATH=/opt/radio/session.lock
# TRACK_INDEX_PATH=/opt/radio/track_index.json
# RADIO_QUEUE_DIR=/opt/radio/queue
# RADIO_CACHE_DIR=/opt/radio/cache
# EXCLUDED_IDS_PATH=/opt/radio/excluded_ids.json
# PLAY_HISTORY_PATH=/opt/radio/play_history.json
# ALBUM_PLAY_HISTORY_PATH=/opt/radio/album_play_history.json
# PLAYING_HISTORY_PATH=/opt/radio/cache/.history.json
# ICECAST_WEBROOT=/usr/share/icecast2/web

# Where publish_now_playing.py's prefetch_enrich() stashes description/
# video-id lookups it ran ahead of time for the track queue_list_writer.py
# decided was coming up soon, so they're ready instantly once that track
# is actually live instead of leaving a few-second gap with no info shown.
# PREFETCH_DIR=/opt/radio/prefetch_enrich

# Path to the Liquidsoap admin socket (see liquidsoap/radio.liq's
# settings.server.socket.path) -- admin_app.py's "skip track" button talks
# to it directly over this Unix socket, no network exposure at all.
# LIQUIDSOAP_SOCKET_PATH=/run/liquidsoap-radio.sock

# Station name shown on the Telegram RTMP broadcast's rendered video frame
# (see tgstream/render_frame.py) and used as the Telegram handle's display
# fallback.
# RADIO_STATION_NAME=Your Radio

# Only needed on a standby/backup video encoder that doesn't run its own
# radio pipeline locally -- points it at the primary encoder's icecast
# webroot over HTTP instead of reading nowplaying.json/queue.json/cover.jpg
# from disk.
# RADIO_BASE_URL=
