[Unit]
Description=MusicmaniA Radio (Liquidsoap)
After=network-online.target icecast2.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/radio
EnvironmentFile=/etc/musicbestman/env
ExecStart=/usr/bin/liquidsoap /opt/radio/radio.liq
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
